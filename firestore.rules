rules_version = '2';

// Firestore rules for blog post engagement.
//
// Intentionally minimal: any visitor may read stats and bump counters on the
// postStats collection. Everything else is locked down.
// Client-side spam protection (sessionStorage / localStorage) is enough for a
// personal blog; the rules only ensure no one writes to other collections.

service cloud.firestore {
  match /databases/{database}/documents {

    match /postStats/{postId} {
      allow read: if true;
      allow write: if onlyEngagementFields();
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Only the three known top-level fields may appear in the written document.
function onlyEngagementFields() {
  return request.resource.data.keys().hasOnly(['views', 'shares', 'reactions']);
}
