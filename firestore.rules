rules_version = '2';

// Public article counters are intentionally readable and writable without
// Firebase Auth. Rules constrain document ids, fields, types, and every delta;
// App Check provides abuse resistance. These remain best-effort signals, not
// financial, entitlement, or audit-grade records.
service cloud.firestore {
  match /databases/{database}/documents {
    function validPostId(postId) {
      return postId.size() <= 256
        && postId.matches('^[a-z0-9][a-z0-9-]*__[a-z0-9][a-z0-9-]*$');
    }

    function reactionMap(data) {
      return data.get('reactions', {});
    }

    function reactionValue(reactions, key) {
      return reactions.get(key, 0);
    }

    function validReactionMap(reactions) {
      return reactions is map
        && reactions.keys().hasOnly(['like', 'love', 'insightful', 'clap'])
        && reactionValue(reactions, 'like') is int
        && reactionValue(reactions, 'like') >= 0
        && reactionValue(reactions, 'love') is int
        && reactionValue(reactions, 'love') >= 0
        && reactionValue(reactions, 'insightful') is int
        && reactionValue(reactions, 'insightful') >= 0
        && reactionValue(reactions, 'clap') is int
        && reactionValue(reactions, 'clap') >= 0;
    }

    function validDocumentShape(data) {
      return data.keys().hasOnly(['views', 'shares', 'reactions'])
        && data.get('views', 0) is int
        && data.get('views', 0) >= 0
        && data.get('shares', 0) is int
        && data.get('shares', 0) >= 0
        && validReactionMap(reactionMap(data));
    }

    function reactionTotal(reactions) {
      return reactionValue(reactions, 'like')
        + reactionValue(reactions, 'love')
        + reactionValue(reactions, 'insightful')
        + reactionValue(reactions, 'clap');
    }

    function validCreate(data) {
      return validDocumentShape(data)
        && data.get('views', 0) <= 1
        && data.get('shares', 0) <= 1
        && reactionValue(reactionMap(data), 'like') <= 1
        && reactionValue(reactionMap(data), 'love') <= 1
        && reactionValue(reactionMap(data), 'insightful') <= 1
        && reactionValue(reactionMap(data), 'clap') <= 1
        && reactionTotal(reactionMap(data)) <= 1
        && data.get('views', 0)
          + data.get('shares', 0)
          + reactionTotal(reactionMap(data)) <= 1;
    }

    function reactionDelta(next, previous, key) {
      return reactionValue(next, key) - reactionValue(previous, key);
    }

    function validReactionDelta(next, previous) {
      let changed = next.diff(previous).affectedKeys();
      let totalDelta = reactionTotal(next) - reactionTotal(previous);
      return changed.size() >= 1
        && changed.size() <= 2
        && reactionDelta(next, previous, 'like') >= -1
        && reactionDelta(next, previous, 'like') <= 1
        && reactionDelta(next, previous, 'love') >= -1
        && reactionDelta(next, previous, 'love') <= 1
        && reactionDelta(next, previous, 'insightful') >= -1
        && reactionDelta(next, previous, 'insightful') <= 1
        && reactionDelta(next, previous, 'clap') >= -1
        && reactionDelta(next, previous, 'clap') <= 1
        && (
          (changed.size() == 1 && (totalDelta == 1 || totalDelta == -1))
          || (changed.size() == 2 && totalDelta == 0)
        );
    }

    function isViewIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views'])
        && request.resource.data.get('views', 0)
          == resource.data.get('views', 0) + 1;
    }

    function isShareIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['shares'])
        && request.resource.data.get('shares', 0)
          == resource.data.get('shares', 0) + 1;
    }

    function isReactionChange() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions'])
        && validReactionDelta(
          reactionMap(request.resource.data),
          reactionMap(resource.data)
        );
    }

    match /postStats/{postId} {
      allow read: if validPostId(postId);
      allow create: if validPostId(postId)
        && validCreate(request.resource.data);
      allow update: if validPostId(postId)
        && validDocumentShape(request.resource.data)
        && (isViewIncrement() || isShareIncrement() || isReactionChange());
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
