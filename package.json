{
  "name": "nguyenlephong",
  "version": "3.0.0",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "next dev -p 10505",
    "build": "node scripts/build-og.mjs --full",
    "build:og": "node scripts/generate-static-og.mjs",
    "build:fast": "node scripts/build-og.mjs --skip",
    "build:force": "node scripts/build-og.mjs --full",
    "analyze": "next experimental-analyze --output",
    "assets:icdn": "node scripts/sync-icdn-assets.mjs",
    "seo:monitor": "node scripts/monitor-seo-field-data.mjs",
    "seo:opportunities": "node scripts/report-search-opportunities.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:firestore-rules": "firebase emulators:exec --only firestore --project demo-engagement-rules \"node --test tests/firestore-rules.test.mjs\"",
    "check": "npm run typecheck && npm run lint && npm test",
    "quality": "npm run check && npm run build:fast && npm run verify:pagination && npm run verify:artifact && npm run verify:performance-artifact && npm run verify:runtime-boundaries && npm run verify:offline",
    "verify:artifact": "node scripts/verify-static-artifact.mjs",
    "verify:performance-artifact": "node scripts/verify-performance-artifact.mjs",
    "verify:runtime-boundaries": "node scripts/verify-runtime-boundaries.mjs",
    "verify:studio-artifact": "node scripts/verify-studio-artifact.mjs",
    "verify:dev-concurrency": "node scripts/verify-dev-concurrency.mjs",
    "verify:not-found": "node scripts/verify-static-not-found.mjs",
    "verify:og-publication": "node scripts/verify-og-publication.mjs",
    "verify:og-publication:live": "node scripts/verify-og-publication.mjs --live",
    "verify:pagination": "node scripts/verify-content-pagination.mjs",
    "verify:offline": "node scripts/verify-offline.mjs",
    "og:generate": "node scripts/generate-static-og.mjs",
    "og:generate:blog": "node scripts/generate-static-og.mjs --surface blog",
    "og:generate:notes": "node scripts/generate-static-og.mjs --surface notes",
    "og:publish:dry-run": "node scripts/publish-og-assets.mjs --dry-run",
    "sonar": "sonar-scanner",
    "sonar:check": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "fb-deploy": "npm run verify:artifact && npm run verify:performance-artifact && firebase deploy --only hosting",
    "deploy:legacy": "ALLOW_LEGACY_PAGES_DEPLOY=1 node scripts/deploy-pages.mjs",
    "deploy:legacy:build": "node scripts/bump-version.mjs && npm run build && npm run deploy:legacy"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "d3-drag": "3.0.0",
    "d3-force": "3.0.0",
    "d3-selection": "3.0.0",
    "d3-transition": "3.0.1",
    "firebase": "^12.14.0",
    "framer-motion": "12.9.4",
    "next": "16.2.10",
    "next-intl": "4.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.0.1",
    "recharts": "^3.8.0",
    "schema-dts": "1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@types/d3-drag": "3.0.7",
    "@types/d3-force": "3.0.10",
    "@types/d3-selection": "3.0.11",
    "@types/d3-transition": "3.0.9",
    "@types/node": "22",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "entities": "8.0.0",
    "eslint": "9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "9.1.0",
    "firebase-tools": "15.24.0",
    "playwright": "1.61.1",
    "postcss": "^8.5.20",
    "postcss-selector-parser": "^7.1.4",
    "prettier": "3.2.5",
    "sharp": "^0.33.5",
    "typescript": "5"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "nanoid": "3.3.16"
  }
}
