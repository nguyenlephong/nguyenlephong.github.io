{
  "name": "nguyenlephong",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 10505",
    "build": "node scripts/build-og.mjs --full",
    "build:og": "node scripts/generate-static-og.mjs",
    "build:fast": "node scripts/build-og.mjs --skip",
    "build:force": "node scripts/build-og.mjs --full",
    "assets:icdn": "node scripts/sync-icdn-assets.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run typecheck && npm run lint && npm test",
    "quality": "npm run check && npm run build:fast && npm run verify:offline",
    "verify:offline": "node scripts/verify-offline.mjs",
    "og:generate": "node scripts/generate-static-og.mjs",
    "sonar": "sonar-scanner",
    "sonar:check": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "predeploy": "node scripts/bump-version.mjs && bun run build",
    "fb-deploy": "firebase deploy",
    "deploy": "bun run deploy:out",
    "deploy:out": "node scripts/deploy-pages.mjs",
    "deploy:fast": "node scripts/bump-version.mjs && bun run build && bun run deploy:out"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "d3-drag": "3.0.0",
    "d3-force": "3.0.0",
    "d3-selection": "3.0.0",
    "d3-transition": "3.0.1",
    "dayjs": "1.11.13",
    "eslint-config-prettier": "9.1.0",
    "firebase": "^12.14.0",
    "framer-motion": "12.9.4",
    "gh-pages": "6.1.1",
    "next": "16.1.1",
    "next-intl": "4.12.0",
    "prettier": "3.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.0.1",
    "recharts": "^3.8.0",
    "schema-dts": "1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/d3-drag": "3.0.7",
    "@types/d3-force": "3.0.10",
    "@types/d3-selection": "3.0.11",
    "@types/d3-transition": "3.0.9",
    "@types/node": "20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9",
    "eslint-config-next": "16.1.1",
    "playwright": "1.61.1",
    "sharp": "^0.33.5",
    "typescript": "5"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
