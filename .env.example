# Copy to .env and fill in. All values are build-time public (NEXT_PUBLIC_*).

NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_VERSION=v1.0.0

# --- Firebase (Firestore) — blog engagement: views · reactions · share ---
# Firebase Console → Project settings → General → "Your apps" → Web app config.
# Public-safe (protected by firestore.rules). Leave the feature disabled by
# leaving these blank — the site no-ops gracefully when unset.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — derived from PROJECT_ID when blank:
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# App Check policy: "optional" preserves fail-soft reads/writes (default), while
# "required" disables every engagement write unless App Check becomes active.
# Reads remain fail-soft in both modes. Any other non-empty value fails closed.
NEXT_PUBLIC_FIREBASE_APPCHECK_MODE=optional
# Public reCAPTCHA Enterprise site key. Required when mode is "required".
# Firebase Console enforcement is a separate external rollout step: monitor
# valid/invalid traffic first, then enable Firestore enforcement in the console.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# --- Public media delivery ---
# Public base URL only (for example an R2 custom domain). Never expose R2 API
# tokens, S3 access keys, signing keys, or private bucket credentials here.
# Defaults to the current dom-pub ICDN base when blank.
NEXT_PUBLIC_MEDIA_BASE_URL=
